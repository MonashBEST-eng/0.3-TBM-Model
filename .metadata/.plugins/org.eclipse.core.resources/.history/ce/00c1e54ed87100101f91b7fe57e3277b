/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_TIM1_Init();
  Motor_Init();
  /* USER CODE BEGIN 2 */

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {

	    // 1. Forward 50%
	    Motor_Enable(1); // Ensure driver is enabled
	    Motor_SetSpeed(50);
	    HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_SET); // Visual feedback
	    if (Motor_IsFault()) Error_Handler();
	    HAL_Delay(2000);

	    // 2. Active brake
	    Motor_Stop();
	    HAL_GPIO_WritePin(LD2_GPIO_Port, LD2_Pin, GPIO_PIN_RESET);
	    if (Motor_IsFault()) Error_Handler();
	    HAL_Delay(1000);

	    // 3. Reverse 30%
	    Motor_SetSpeed(-30);
	    HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin); // Toggle LED
	    if (Motor_IsFault()) Error_Handler();
	    HAL_Delay(2000);

	    // 4. Coast
	    Motor_Coast();
	    HAL_GPIO_TogglePin(LD2_GPIO_Port, LD2_Pin);
	    if (Motor_IsFault()) Error_Handler();
	    HAL_Delay(1000);

	    Motor_Stop();
	    HAL_Delay(500);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

