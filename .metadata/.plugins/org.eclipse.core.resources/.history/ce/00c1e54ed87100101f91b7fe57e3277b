// Speed is a percentage value -100-100
// (+ve for forward, -ve for reverse)
void Motor_SetSpeed(int8_t speed)
{
    uint16_t pwm_val;

    // do not exceed range
    if (speed > 100) speed = 100;
    if (speed < -100) speed = -100;

    // convert percentage to PWM
    pwm_val = (uint16_t)((abs(speed) * 65535) / 100);

    if (speed > 0) {
        // forwards
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL1, pwm_val);
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL2, 0);
    }
    else if (speed < 0) {
        // reverse
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL1, 0);
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL2, pwm_val);
    }
    else {
        // brake
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL1, 0);
        __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL2, 0);
    }
}

// Stop motor: active brake (shorts to GND) (can is handle current surge?)
void Motor_Stop(void)
{
    // Both channels high for active brake
    __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL1, 65535);
    __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL2, 65535);
}

// Coast motor
void Motor_Coast(void)
{
    // Both channels low for coast
    __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL1, 0);
    __HAL_TIM_SET_COMPARE(&htim1, MOTOR_PWM_CHANNEL2, 0);
}

// Check for faults
int Motor_IsFault(void)
{
    return (HAL_GPIO_ReadPin(MOTOR_NFAULT_PORT, MOTOR_NFAULT_PIN) == GPIO_PIN_RESET);
}

// Enable motor
void Motor_Enable(int enable)
{
    HAL_GPIO_WritePin(MOTOR_NSLEEP_PORT, MOTOR_NSLEEP_PIN, enable ? GPIO_PIN_SET : GPIO_PIN_RESET);
}
