#!/bin/sh

commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|test|chore)(\([a-z0-9._-]+\))?: .+"

if ! echo "$commit_msg" | grep -Eq "$pattern"; then
  echo "❌ Invalid commit message:"
  echo "$commit_msg"
  echo
  echo "➡️  Use format like:"
  echo "   feat(login): add authentication logic"
  echo "   fix: correct typo in README"
  exit 1
fi
